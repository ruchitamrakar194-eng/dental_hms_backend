PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/dental_hms_saas"

# Auth
JWT_SECRET="change_me"
JWT_REFRESH_SECRET="change_me"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI (Optional). If empty, server uses safe local fallback.
OPENAI_API_KEY=""

# Stripe (Optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# Frontend URL (for billing redirects)
FRONTEND_URL=http://localhost:5173
